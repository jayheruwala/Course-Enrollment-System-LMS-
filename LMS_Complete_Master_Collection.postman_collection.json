                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Jane Instructor\",\n    \"email\": \"instructor@test.com\",\n    \"password\": \"password123\",\n    \"role\": \"INSTRUCTOR\",\n    \"expertise\": \"Java\",\n    \"bio\": \"Senior Developer\"\n}"
